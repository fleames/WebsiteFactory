{
  "name": "website-factory",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate": "tsx renderer/index.ts",
    "example": "tsx renderer/index.ts schema/examples/electrician-berlin.json dist/electrician-berlin",
    "ai": "tsx ai/index.ts",
    "builder": "tsx builder/server.ts",
    "builder:build": "vite build --config builder/vite.config.ts",
    "builder:dev": "concurrently \"tsx --watch builder/server.ts\" \"vite --config builder/vite.config.ts\""
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
